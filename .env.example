PANEL_ENV=production

# Database configuration
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=panel_db
DB_USER=panel_user
DB_PASS=REPLACE_DB_PASS

# Redis configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Panel Admin Password Hash (BCrypt)
# Default is 'admin', you should change it!
PANEL_USER=admin
PANEL_PASSWORD_HASH=REPLACE_PANEL_HASH

# System Features
FIREWALL_UFW_ENABLED=true
CLOUDFLARE_ENABLED=false
CF_API_TOKEN=

# Server IP
SERVER_IP=127.0.0.1
